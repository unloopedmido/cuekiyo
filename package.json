{
  "name": "cuekiyo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Cuekiyo — local studio for anime opening and ending compilations",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unloopedmido/cuekiyo.git"
  },
  "bugs": {
    "url": "https://github.com/unloopedmido/cuekiyo/issues"
  },
  "homepage": "https://github.com/unloopedmido/cuekiyo#readme",
  "engines": {
    "node": ">=24.16.0 <25"
  },
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "bash scripts/run-backend.sh --reload --host 127.0.0.1 --port 8000",
    "dev:frontend": "cd frontend && npm run dev",
    "start": "npm run build:frontend && PIPELINE_SERVE_FRONTEND=1 npm run start:backend",
    "start:backend": "bash scripts/run-backend.sh --host 127.0.0.1 --port 8000",
    "build:frontend": "cd frontend && npm run build",
    "lint": "eslint frontend",
    "doctor:react": "cd frontend && npm run doctor:react",
    "fallow": "cd frontend && npm run fallow",
    "fallow:dead-code": "cd frontend && npm run fallow:dead-code --",
    "fallow:health": "cd frontend && npm run fallow:health --",
    "format": "prettier --write \"frontend/**/*.{ts,tsx}\"",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && python -m pytest -q",
    "test:frontend": "cd frontend && npm test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript-eslint": "^8.59.4"
  }
}
