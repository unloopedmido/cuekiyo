{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "ignorePatterns": [
    "src/components/ui/**",
    "src/assets/**",
    "src/hooks/use-mobile.ts",
    "dist/**"
  ],
  "ignoreDependencies": [
    "babel-plugin-react-compiler",
    "@fontsource/noto-sans-jp",
    "class-variance-authority",
    "cmdk",
    "next-themes",
    "radix-ui"
  ],
  "duplicates": {
    "minLines": 15
  },
  "health": {
    "maxCyclomatic": 50,
    "maxCognitive": 40,
    "maxCrap": 2200
  }
}
