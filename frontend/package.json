{
  "name": "cuekiyo-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.16.0 <25",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json && vite build",
    "test": "node --test tests/*.test.ts",
    "lint": "cd .. && eslint frontend",
    "doctor:react": "react-doctor . --yes --offline --no-dead-code --fail-on error",
    "fallow": "fallow audit --base HEAD --quiet",
    "fallow:dead-code": "fallow dead-code",
    "fallow:health": "fallow health",
    "format": "prettier --config ../.prettierrc --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json",
    "preview": "vite preview",
    "render-overlay": "node scripts/render-overlay.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource-variable/outfit": "^5.2.8",
    "@fontsource/noto-sans-jp": "^5.2.8",
    "@hugeicons/core-free-icons": "^4.1.4",
    "@hugeicons/react": "^1.1.6",
    "@resvg/resvg-js": "^2.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "satori": "^0.12.2",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@rolldown/plugin-babel": "^0.2.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "fallow": "^2.78.0",
    "react-doctor": "^0.2.2",
    "typescript": "~6.0.3",
    "vite": "^8.0.14"
  }
}
